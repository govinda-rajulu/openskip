{
  "manifest_version": 2,
  "name": "SkipStream",
  "description": "Automatically skip intros, recaps, and outros - and resume playback across all your devices.",
  "version": "1.8.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "32": "icons/icon-32.png"
  },
  "permissions": [
    "<all_urls>",
    "alarms",
    "storage",
    "tabs"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src https://api.themoviedb.org https://image.tmdb.org https://api.introdb.app https://api.anime-skip.com https://*.supabase.co https://i.ytimg.com https://open.spotify.com https://soundcloud.com https://api.opensubtitles.com https://vip-api.opensubtitles.com",
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "browser_action": {
    "default_title": "SkipStream",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "32": "icons/icon-32.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": false,
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "js": [
        "content-scripts/content.js"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "skipstream@extension",
      "strict_min_version": "140.0"
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Open SkipStream popup"
    }
  }
}
