{
  "manifest_version": 3,
  "name": "SkipStream",
  "description": "Automatically skip intros, recaps, and outros - and resume playback across all your devices.",
  "version": "1.7.2",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "alarms",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://api.themoviedb.org https://image.tmdb.org https://api.introdb.app https://api.anime-skip.com https://*.supabase.co https://i.ytimg.com https://open.spotify.com https://soundcloud.com https://api.opensubtitles.com https://vip-api.opensubtitles.com"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SkipStream",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "js": [
        "content-scripts/content.js"
      ]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Open SkipStream popup"
    }
  }
}